# .env.example - Template pour les variables d'environnement

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_to_a_random_string_in_production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: "mysql://user:password@host:port/db_name?serverVersion=8.0"
# Pour développement local
DATABASE_URL="mysql://symfony:symfony@mysql:3306/symfony?serverVersion=8.0&charset=utf8mb4"
# Pour production
# DATABASE_URL="mysql://user:password@prod-host:3306/database?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> Environnement de Production ###
# Décommenter et configurer pour la production
# APP_ENV=prod
# APP_DEBUG=0
# CORS_ALLOW_ORIGIN=https://your-domain.com
###< Environnement de Production ###
